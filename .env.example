# Required
M365_CLIENT_ID=your-app-registration-client-id
M365_TENANT_ID=your-entra-id-tenant-id

# Optional — set for confidential client (auth code flow)
# M365_CLIENT_SECRET=your-client-secret

# Optional — defaults
# M365_TOKEN_CACHE=~/.m365_token_cache.json
# M365_TIMEZONE=UTC
# M365_REDIRECT_URI=http://localhost:19365/auth/callback
